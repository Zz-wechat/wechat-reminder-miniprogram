<!-- pages/index/index.wxml - 首页结构 -->
<view class="container">
  <!-- 标题 -->
  <view class="title">微信提醒工具</view>
  <view class="subtitle">简单好用的提醒助手</view>
  
  <!-- 快速创建按钮 -->
  <view class="card">
    <navigator url="/pages/reminder/create" hover-class="none">
      <view class="button" style="background-color: #07c160;">
        ＋ 创建新提醒
      </view>
    </navigator>
  </view>
  
  <!-- 今日提醒 -->
  <view class="card">
    <view style="font-size: 36rpx; font-weight: bold; margin-bottom: 30rpx;">
      📅 今日提醒
      <text style="font-size: 28rpx; color: #999; margin-left: 20rpx;">
        {{todayCount}} 个
      </text>
    </view>
    
    <!-- 提醒列表 -->
    <view wx:if="{{todayReminders.length > 0}}">
      <view wx:for="{{todayReminders}}" wx:key="index" class="reminder-item" 
            style="border-left: 8rpx solid #07c160; padding-left: 20rpx; margin-bottom: 30rpx;">
        <view class="content">{{item.content}}</view>
        <view class="time">
          ⏰ {{item.time}} {{item.date === 'today' ? '今天' : item.date}}
        </view>
      </view>
    </view>
    
    <view wx:else class="empty">
      🎉 今天没有提醒，放松一下吧！
    </view>
  </view>
  
  <!-- 查看所有提醒 -->
  <view class="card">
    <navigator url="/pages/reminder/list" hover-class="none">
      <view class="button" style="background-color: #007aff;">
        📋 查看所有提醒
      </view>
    </navigator>
  </view>
  
  <!-- 使用提示 -->
  <view class="card" style="background-color: #f0f9ff; border-left: 8rpx solid #007aff;">
    <view style="font-size: 32rpx; font-weight: bold; color: #007aff; margin-bottom: 15rpx;">
      💡 使用小贴士
    </view>
    <view style="font-size: 28rpx; color: #666; line-height: 1.6;">
      1. 点击"创建新提醒"设置提醒<br/>
      2. 时间到了会收到通知<br/>
      3. 可以在列表页管理所有提醒
    </view>
  </view>
</view>