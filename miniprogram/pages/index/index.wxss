/* pages/index/index.wxss - 首页样式 */

/* 提醒项样式 */
.reminder-item {
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}

/* 响应式调整 */
@media (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.reminder-item {
  animation: fadeIn 0.3s ease-out;
}