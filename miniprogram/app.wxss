/* app.wxss - 全局样式文件 */

/* 基础样式重置 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 16px;
  line-height: 1.5;
  color: #333;
  background-color: #f5f5f5;
}

/* 容器样式 */
.container {
  padding: 20rpx;
}

/* 按钮基础样式 */
.button {
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.button:active {
  background-color: #06ad56;
}

/* 输入框样式 */
.input {
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
  background-color: white;
  margin: 20rpx 0;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

/* 标题样式 */
.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

/* 副标题 */
.subtitle {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 30rpx;
}

/* 时间显示 */
.time {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 提醒内容 */
.content {
  font-size: 36rpx;
  margin: 20rpx 0;
  color: #333;
}

/* 空状态提示 */
.empty {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
  font-size: 32rpx;
}

/* 操作按钮组 */
.actions {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  margin: 0 10rpx;
  padding: 15rpx;
  border-radius: 6rpx;
  text-align: center;
  font-size: 28rpx;
}

.delete-btn {
  background-color: #ff3b30;
  color: white;
}

.edit-btn {
  background-color: #007aff;
  color: white;
}

.complete-btn {
  background-color: #34c759;
  color: white;
}